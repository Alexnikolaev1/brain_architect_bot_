# 🧠 Архитектор Мозга — переменные окружения
# Скопируй в .env и заполни значения

# Telegram Bot Token (от @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Для ЛОКАЛЬНОГО запуска достаточно только TELEGRAM_BOT_TOKEN.
# Если поля ниже не заданы, бот автоматически использует in-memory storage.

# MongoDB Atlas (опционально для локалки, обязательно для прода)
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=brain_architect

# Upstash Redis (опционально для локалки, обязательно для прода)
# UPSTASH_REDIS_URL=rediss://your-endpoint.upstash.io:6379
# UPSTASH_REDIS_PASSWORD=your_redis_password
